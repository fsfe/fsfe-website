msgid "Unlock Education in the Netherlands"
msgstr ""

#. type: Content of: <activityset><activity><description>
#: fsfe.org/activities/nledu/activity.en.xml:8
#, no-wrap
msgid ""
"    This activity was specifically targeted at the Dutch education sector, with \n"
"    the aim of enabling citizens to have free access to education and public \n"
"    institutions, both online and offline. By promoting the mandatory use of \n"
"    Open Standards and platform-independent access to all materials, students \n"
"    and parents will be able fulfil their potential for personal growth and \n"
"    development without being dependent on a company. \n"
"    "
msgstr ""
