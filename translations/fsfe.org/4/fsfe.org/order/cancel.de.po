#. type: Content of: <html><body><h1>
#: fsfe.org/order/cancel.en.xhtml:6 fsfe.org/order/cancel.en.xhtml:14
#, priority:300
msgid "Payment cancelled"
msgstr "Zahlung abgebrochen"

#. type: Content of: <html><body><p>
#: fsfe.org/order/cancel.en.xhtml:11 fsfe.org/order/thankyou.en.xhtml:11
#, priority:300
msgid "<a href=\"/order/order.html\">Merchandise</a>"
msgstr "<a href=\"/order/order.html\">Fanartikel</a>"

#. type: Content of: <html><body><p>
#: fsfe.org/order/cancel.en.xhtml:17
#, priority:300
msgid "Your online payment has been cancelled. No money will be transferred."
msgstr "Ihre Online-Zahlung wurde abgebrochen. Es wird kein Geld abgebucht."

#. type: Content of: <html><body><p>
#: fsfe.org/order/cancel.en.xhtml:21
#, priority:300
msgid ""
"If the abort was caused by a problem on our side, please <a "
"href=\"mailto:contact@fsfe.org\">tell us about it</a> so we can improve our "
"infrastructure. In any case, you can also try to <a "
"href=\"order.html\">restart the process</a> now."
msgstr ""
"Falls der Abbruch durch ein Problem auf unserer Seite verursacht wurde, <a "
"href=\"mailto:contact@fsfe.org\">informieren Sie uns bitte davon</a>, damit "
"wir unsere Infrastruktur verbessern können. In jedem Fall können Sie auch "
"versuchen, den <a href=\"order.html\">Prozess neu zu starten</a>."

#. type: Content of: <html><followup>
#: fsfe.org/order/cancel.en.xhtml:28
#, priority:300
msgid "no"
msgstr "no"
