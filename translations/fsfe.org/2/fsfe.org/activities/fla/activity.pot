msgid "Fiduciary Programme"
msgstr ""

#. type: Content of: <activityset><activity><description>
#: fsfe.org/activities/fla/activity.en.xml:8
#, no-wrap
msgid ""
"    The Fiduciary License Agreement (FLA) allows software projects to assign \n"
"    copyrights to a named fiduciary for its effective management. This allows \n"
"    developers to focus on development rather than spending time on legal \n"
"    administration. While the FSFE is no longer accepting new projects under the \n"
"    Fiduciary Programme, we continue to offer customisable versions of the FLA \n"
"    for your use. \n"
"        "
msgstr ""
